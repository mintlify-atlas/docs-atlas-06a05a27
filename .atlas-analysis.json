  "keyFeatures": [
    "Video tutorial courses and formations (cursus)",
    "Premium subscription system with Stripe and PayPal",
    "Community forum with topics and tags",
    "Blog with categories and posts",
    "User authentication with OAuth (GitHub, Google, Facebook, Discord)",
    "Badge and achievement system",
    "Admin panel for content and user management",
    "Search powered by a custom search index",
    "Real-time notifications via Mercure",
    "School/group learning features",
    "Live streaming integration (Twitch/YouTube)"
  ],
